{
    "name": "blueticks/blueticks",
    "description": "Official PHP SDK for the Blueticks API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["blueticks", "whatsapp", "api", "sdk"],
    "homepage": "https://github.com/serenix-com/blueticks-php",
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "php-http/mock-client": "^1.6",
        "guzzlehttp/psr7": "^2.6",
        "guzzlehttp/guzzle": "^7.8",
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": { "Blueticks\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Blueticks\\Tests\\": "tests/" }
    },
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml",
        "lint-fix": "phpcbf --standard=phpcs.xml",
        "analyse": "phpstan analyse --memory-limit=512M",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
